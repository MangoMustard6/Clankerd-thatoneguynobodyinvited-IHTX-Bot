# Copy this file to .env and fill in your values.
# Never commit the real .env to version control.

# Your Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# Your Groq Cloud API key (from https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# ── Optional tuning ─────────────────────────────────────────────────────────

# Groq model to use (default: llama-3.3-70b-versatile)
# Other options: mixtral-8x7b-32768, llama-3.1-8b-instant, gemma2-9b-it
# GROQ_MODEL=llama-3.3-70b-versatile

# Number of past messages kept per channel for context (default: 14)
# MAX_HISTORY=14

# Maximum tokens in each AI response (default: 1024)
# MAX_RESPONSE_TOKENS=1024

# Path to the user profiles JSON file (default: user_profiles.json)
# PROFILES_PATH=user_profiles.json
