modules = ["python-3.11", "nodejs-20", "web"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "IHTX Discord Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "IHTX Discord Bot (TypeScript)"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Pipeline Visualizer"

[[workflows.workflow]]
name = "IHTX Discord Bot"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PYTHONUNBUFFERED=1 python3 -u main.py"

[[workflows.workflow]]
name = "IHTX Discord Bot (TypeScript)"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/discord-bot run dev"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Pipeline Visualizer"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8000 node public/serve.mjs"
waitForPort = 8000

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = []

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8082
externalPort = 3000

[[ports]]
localPort = 8083
externalPort = 3001

[[ports]]
localPort = 8084
externalPort = 3002

[[ports]]
localPort = 8000
externalPort = 8000

[userenv]

[userenv.shared]
PORT = "8081"

[nix]
channel = "stable-25_05"
packages = ["libuv", "rubberband"]
